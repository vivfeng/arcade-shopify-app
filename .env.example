# Shopify app credentials (from Shopify Partners dashboard)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# App URL (set automatically by `shopify app dev`, or your production URL)
SHOPIFY_APP_URL=

# Scopes (also defined in shopify.app.toml)
SCOPES=read_products,write_products,read_orders,write_orders,read_fulfillments,write_fulfillments

# PostgreSQL connection string
DATABASE_URL=

# Arcade backend API
ARCADE_API_URL=
ARCADE_API_KEY=

# Firebase (VITE_ prefix = exposed to the browser)
VITE_FIREBASE_WEB_API_KEY=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=

# Firebase Admin SDK (server-only, never exposed to browser)
FIREBASE_SERVICE_ACCOUNT_KEY=