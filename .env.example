# Shopify app credentials (from Shopify Partners dashboard)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# App URL (set automatically by `shopify app dev`, or your production URL)
SHOPIFY_APP_URL=

# Scopes (also defined in shopify.app.toml)
SCOPES=read_products,write_products,read_orders,write_orders,read_fulfillments,write_fulfillments

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/arcade_shopify?schema=public

# Arcade backend API
ARCADE_API_URL=
ARCADE_API_KEY=

# Optional: custom shop domain
# SHOP_CUSTOM_DOMAIN=
